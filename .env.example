# Copy this file to .env and fill in the values.
# Never commit .env to version control.

# Required for live trading only — prefer env var over config.yml
PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# Required for live trading — Base mainnet RPC
RPC_URL=https://mainnet.base.org

# Optional — override config.yml values at runtime
# MCP_SESSION_TOKEN=your_token_here
